                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "    pm.expect(jsonData.data.id).to.eql(2);",
                  "    pm.expect(jsonData.data.email).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://reqres.in/api/users/2",
              "protocol": "https",
